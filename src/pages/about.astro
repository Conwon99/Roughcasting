---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { CTASection } from "@/sections/Footer/components/CTASection";
import { Footer } from "@/sections/Footer";
import { locations } from "@/data/locations";
import { TrackedTelLink } from "@/components/TrackedTelLink";
import { categories } from "@/data/categories";
import { absoluteUrl, brandName, business, citiesLabel } from "@/data/business";

const brand = brandName();
const cities = citiesLabel();
const canonical = absoluteUrl("/about");
const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: `About ${brand} | ${cities} Roughcasting & Rendering Specialists`,
  description: `Meet ${brand} — locally trusted roughcasting, render and plastering specialists serving ${cities} and ${business.region}.`,
  isPartOf: { "@id": `${absoluteUrl("/")}#website` },
  about: { "@id": `${absoluteUrl("/")}#business` },
  inLanguage: "en-GB",
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: "About", item: canonical },
  ],
};
---

<BaseLayout
  title={`About ${brand} | ${cities} Roughcasting & Rendering Specialists`}
  description={`Meet ${brand}. Locally trusted roughcasting, render and plastering serving ${cities} and surrounding Ayrshire. Free quotes available.`}
  canonical={canonical}
>
  <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
    <Header client:load />
    <main>
      <section class="box-border caret-transparent pt-[160px] pb-[70px] md:pt-[220px] md:pb-[100px]">
        <div class="box-border caret-transparent max-w-[980px] mx-auto px-5 md:px-8 text-center">
          <p class="text-[#16a34a] text-sm font-semibold uppercase tracking-[0.18em] mb-4">About Us</p>
          <h1 class="text-white text-[34px] font-bold leading-[44px] mb-5 md:text-[64px] md:leading-[78px]">
            About {brand} — Your Local {cities} Specialists
          </h1>
          <p class="text-slate-200 max-w-[720px] mx-auto mb-8">Locally owned. Professionally trained. Here when you need us.</p>
          <TrackedTelLink
            client:load
            showPhoneNumber
            prefix="Call "
            className="text-white text-base bg-[#15803d] font-bold border border-[#15803d] px-8 py-4 rounded-[50px] hover:bg-[#16a34a] transition-colors inline-flex"
            trackingLocation="about"
          />
        </div>
      </section>

      <section class="box-border caret-transparent pb-[60px]">
        <div class="box-border caret-transparent max-w-[980px] mx-auto px-5 md:px-8">
          <div class="bg-white rounded-[20px] p-6 md:p-10 space-y-10">
            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">How {brand} Got Started</h2>
              <p class="text-gray-700 leading-7">{brand} was set up by Joe Kelly in Irvine in March 2022, starting out with garden wall and patchwork jobs before building a reputation right across {business.region}. Word of mouth and repeat customers have grown the business steadily, from small repairs to full house re-renders taken right back to the brick. Customers consistently mention Joe's work ethic, clear communication and tidy finish — the same values the business is built on today.</p>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Meet the Team</h2>
              <div class="flex flex-col md:flex-row gap-6 items-start">
                <div class="w-32 h-32 rounded-full bg-gray-200 shrink-0 overflow-hidden">
                  <img src={business.assets.about} alt={`${brand} team at work`} width="128" height="128" class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div>
                  <h3 class="text-gray-900 text-xl font-bold mb-1">Joe Kelly — {brand}</h3>
                  <p class="text-gray-600 text-sm mb-3">Owner & Roughcaster</p>
                  <p class="text-gray-700 leading-7">Joe is a self-employed roughcaster based in Irvine, covering everything from garden walls and garages to full house roughcasting, smooth render and plastering. Customers regularly highlight his hard work, reliability and the way he keeps them updated from first message through to the finished job.</p>
                </div>
              </div>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Video Introduction</h2>
              <!-- AI: embed owner introduction video if available -->
              <div class="rounded-xl bg-gray-100 border border-gray-200 p-8 text-center text-gray-500">
                <p>Video embed placeholder — add if available from business</p>
              </div>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Proudly Serving {cities} and Surrounding Areas</h2>
              <p class="text-gray-700 leading-7 mb-4">{brand} covers roughcasting, render and plastering work across {business.region}. <a href="/locations" class="text-[#16a34a] hover:underline font-medium">View all service areas</a>.</p>
              <div class="grid grid-cols-2 gap-2 md:grid-cols-3">
                {locations.map((location) => (
                  <a href={`/locations/${location.slug}`} class="text-[#16a34a] hover:underline text-sm">{location.name}</a>
                ))}
              </div>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Why Customers Choose {brand}</h2>
              <ul class="text-gray-700 space-y-2 list-disc pl-5">
                <li>Free quotes on all work</li>
                <li>Tidy workmanship and clear communication throughout the job</li>
                <li>Trusted by customers across {cities} since 2022</li>
                <li>Jobs of every size, from garden walls to full house re-renders</li>
              </ul>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Our Services</h2>
              <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                {categories.map((category) => (
                  <a href={`/${category.slug}`} class="text-[#16a34a] hover:underline">{category.title}</a>
                ))}
              </div>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Find Us on Google</h2>
              <!-- AI: paste Google Business Profile embed code -->
              <div class="rounded-xl overflow-hidden border border-gray-200 h-64 bg-gray-100 flex items-center justify-center text-gray-500">
                <p>Google Business Profile embed placeholder — paste your embed code here</p>
              </div>
              <a href={business.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-[#16a34a] hover:underline">View on Google Maps</a>
            </div>

            <div>
              <h2 class="text-gray-900 text-2xl font-bold mb-4 md:text-3xl">Follow Us</h2>
              <a href={business.facebookUrl} target="_blank" rel="noopener noreferrer" class="text-[#16a34a] hover:underline">{brand} on Facebook</a>
            </div>
          </div>
        </div>
      </section>

      <section class="box-border caret-transparent pb-[80px]">
        <div class="box-border caret-transparent max-w-[980px] mx-auto px-5 md:px-8">
          <h2 class="text-white text-2xl font-bold mb-4 text-center md:text-3xl">See What Our Customers Say</h2>
          <div class="rounded-xl bg-neutral-900/75 border border-white/10 p-8 text-center text-slate-300 min-h-[200px] flex items-center justify-center">
            <p>Google Reviews widget placeholder — paste your embed code here. <a href="/reviews" class="text-[#16a34a] hover:underline">View reviews on our website</a></p>
          </div>
        </div>
      </section>

      <CTASection client:load />
    </main>
    <Footer client:load />
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
