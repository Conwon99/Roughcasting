---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { HeroSection } from "@/pages/contact/sections/HeroSection";
import { FAQSection } from "@/pages/contact/sections/FAQSection";
import { Footer } from "@/sections/Footer";
import { locations } from "@/data/locations";
import { homepageFaqs, buildFaqSchema } from "@/data/faqs";
import { TrackedTelLink } from "@/components/TrackedTelLink";
import { absoluteUrl, brandName, business, citiesLabel } from "@/data/business";
import { categories } from "@/data/categories";

const brand = brandName();
const serviceList = categories.map((c) => c.name.toLowerCase()).join(", ");
const canonical = absoluteUrl("/contact");
const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: `Contact ${brand} | Free Quotes in ${citiesLabel()}`,
  description: `Contact ${brand} for free quotes on ${serviceList} across ${citiesLabel()} and ${business.region}.`,
  isPartOf: { "@id": `${absoluteUrl("/")}#website` },
  mainEntity: { "@id": `${absoluteUrl("/")}#business` },
  inLanguage: "en-GB",
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: "Contact", item: canonical },
  ],
};
const faqSchema = buildFaqSchema(homepageFaqs);
---

<BaseLayout 
  title={`Contact ${brand} | Free Quotes in ${citiesLabel()}`}
  description={`Contact ${brand} for free quotes on ${serviceList} across ${citiesLabel()} and ${business.region}.`}
  canonical={canonical}
>
    <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
      <Header client:load />
      <HeroSection client:load />

      <section class="box-border caret-transparent pb-[70px] md:pb-[100px]">
        <div class="box-border caret-transparent max-w-[1200px] mx-auto px-[15px] md:px-[30px]">
          <div class="bg-white/5 border border-white/10 rounded-[20px] p-6 md:p-10">
            <h2 class="text-white text-2xl font-bold mb-4 md:text-3xl">Areas We Serve</h2>
            <p class="text-slate-200 mb-6">{brand} covers {citiesLabel()} and towns across {business.region}. Not sure if we serve your area? Call <TrackedTelLink client:load showPhoneNumber className="text-[#16a34a] hover:underline font-semibold" trackingLocation="contact" /> and we will let you know.</p>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-3 lg:grid-cols-4 mb-4">
              {locations.map((location) => (
                <a href={`/locations/${location.slug}`} class="text-slate-200 text-sm hover:text-[#16a34a] hover:underline">{location.name}</a>
              ))}
            </div>
            <a href="/locations" class="text-[#16a34a] hover:underline font-medium text-sm">View all service areas →</a>
          </div>
        </div>
      </section>

      <FAQSection client:load />
      <Footer client:load />
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
